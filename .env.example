# ─── Admin ────────────────────────────────────────────────────────────────────
# Password for the /admin portal. Change before deploying.
ADMIN_PASSWORD=change-this-password

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Canonical public URL — used in WhatsApp messages, JSON-LD structured data,
# and order logs. Priority: SITE_URL → VERCEL_URL (auto-set by Vercel) → data/site.json.
# Set this to your custom domain on production (e.g. https://mummasmenu.in).
# On Vercel preview deploys you can leave it blank — VERCEL_URL is used automatically.
SITE_URL=

# ─── Firebase / Analytics ─────────────────────────────────────────────────────
# Grab these from Firebase Console → Project Settings → Your apps → Web app.
# All NEXT_PUBLIC_ vars are intentionally browser-visible (this is by Firebase SDK design).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
